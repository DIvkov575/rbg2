{
  "name": "remote-claude-shell-manager",
  "version": "0.0.0",
  "private": true,
  "description": "Observe and control many Claude Code sessions across remote desktops from a local terminal UI",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run --filter '*' build",
    "worker": "bun run packages/worker/src/cli.ts",
    "tui": "bun run packages/tui/src/cli.tsx",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0"
  }
}
