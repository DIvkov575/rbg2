{
  "name": "@rcsm/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Remote worker: owns Claude Agent SDK sessions on a desktop and exposes them over the wire protocol",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "rcsm-worker": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --target=node --outdir dist"
  },
  "dependencies": {
    "@rcsm/protocol": "*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12"
  }
}
