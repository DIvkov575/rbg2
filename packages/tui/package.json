{
  "name": "@rcsm/tui",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal Ink terminal client: an agents view over all sessions plus a session view",
  "type": "module",
  "main": "./src/cli.tsx",
  "bin": {
    "rcsm-tui": "./src/cli.tsx"
  },
  "scripts": {
    "start": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --target=node --outdir dist --external react-devtools-core"
  },
  "dependencies": {
    "@rcsm/protocol": "*",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/ws": "^8.5.12"
  }
}
